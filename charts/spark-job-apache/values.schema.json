{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "spark-job-apache values",
  "type": "object",
  "required": ["image", "job"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag":        { "type": "string" }
      }
    },
    "job": {
      "type": "object",
      "required": ["mainApplicationFile"],
      "properties": {
        "mainClass":           { "type": "string" },
        "mainApplicationFile": { "type": "string", "minLength": 1 },
        "pyFiles":             { "type": "string" }
      }
    },
    "runtimeVersions": {
      "type": "object",
      "properties": {
        "sparkVersion": { "type": "string" }
      }
    },
    "driver": {
      "type": "object",
      "properties": {
        "cores":   { "type": "integer", "minimum": 1 },
        "memory":  { "type": "string" }
      }
    },
    "executor": {
      "type": "object",
      "properties": {
        "instances": { "type": "integer", "minimum": 1 },
        "cores":     { "type": "integer", "minimum": 1 },
        "memory":    { "type": "string" }
      }
    },
    "applicationTolerations": {
      "type": "object",
      "properties": {
        "resourceRetainPolicy": {
          "type": "string",
          "enum": ["Never", "OnFailure", "Always"]
        },
        "restartConfig": { "type": "object" },
        "instanceConfig": { "type": "object" },
        "applicationTimeoutConfig": { "type": "object" }
      }
    },
    "sparkConf": { "type": "object" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name":   { "type": "string" }
      }
    }
  }
}
